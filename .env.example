# Backend ----------------------------------------------------------------
# ENTSO-E Transparency Platform API key — used to fetch live Greek DAM prices.
# Without it the ingestion module falls back to a flagged synthetic series.
# Get a free key from https://transparency.entsoe.eu/
ENTSOE_API_KEY=

# Frontend ---------------------------------------------------------------
# Origin where the FastAPI backend is deployed.  Used by next.config.mjs to
# rewrite /api/* requests to the backend Vercel project.
# Leave empty when running everything locally with `vercel dev`.
NEXT_PUBLIC_API_BASE=
